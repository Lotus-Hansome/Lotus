{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe", // 自动对应当前文件的exe
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true, // 改成true可以弹出黑框控制台
            "MIMode": "gdb",
            "miDebuggerPath": "D:/Program Files/mingw64/bin/gdb.exe", // 改成你的gdb路径
            "preLaunchTask": "C/C++: g++.exe 生成活动文件" // 关键！调试前先运行编译任务
        }
    ]
}